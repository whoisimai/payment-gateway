
MERCHANT_ID=your_merchant_id_here
MERCHANT_KEY=your_merchant_key_here
# Optional passphrase (leave blank if not set)
PAYFAST_PASSPHRASE=your_passphrase_here

# URLs used by PayFast for redirects and ITN
RETURN_URL=https://yourdomain.com/return
CANCEL_URL=https://yourdomain.com/cancel
NOTIFY_URL=https://yourdomain.com/api/notify_url

# Local server port
PORT=your_port_here

# Optional: SMS / notification service credentials used in Notify handler, only include this if you have an SMS service set up for notifications
CLIENT_ID=your_sms_client_id_here
API_SECRET=your_sms_api_secret_here
DESTINATION=27820001001

# Toggle to indicate sandbox usage (informational only)
PAYFAST_ENV=sandbox

# Notes:
# - Use sandbox credentials while developing; switch to production endpoints/credentials when ready.

